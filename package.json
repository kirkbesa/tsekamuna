{
  "name": "tsekamuna",
  "version": "0.1.0",
  "description": "Browser extension nudge system for reducing misinformation sharing on Facebook among Filipino users.",
  "scripts": {
    "build": "tsc && tailwindcss -i ./src/input.css -o ./content.css",
    "watch": "concurrently \"tsc --watch\" \"tailwindcss -i ./src/input.css -o ./content.css --watch\""
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "concurrently": "^8.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
